# ============================================
# Pinnacle Concrete Pumping - API Environment (SAMPLE)
# Copy this file to .env and fill in real values.
# ============================================

# Google reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Mail settings
# MAIL_CC and MAIL_BCC accept a single address or a comma-separated list
# Example: MAIL_CC=sales@example.com,manager@example.com
MAIL_TO=info@pinnacleconcretepumping.com.au
MAIL_CC=
MAIL_BCC=
MAIL_FROM=no-reply@pinnacleconcretepumping.com.au
MAIL_FROM_NAME="Pinnacle Concrete Pumping Website"
MAIL_SUBJECT_QUOTE="New Quote Request - Pinnacle Concrete Pumping"
MAIL_SUBJECT_CONTACT="New Contact Enquiry - Pinnacle Concrete Pumping"

# CORS - the front-end origin allowed to call this API
ALLOWED_ORIGIN=https://pinnacleconcretepumping.com.au
